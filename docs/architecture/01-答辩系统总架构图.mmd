  end
  block:L3
    columns 1
    H3["③ 巡逻、导航与系统管理层"]
    SUP["系统编排与软件急停<br/>(system_supervisor_node)<br/>[已实现]"]
    MOTION["受限基础运动技能<br/>(basic_motion_command_node / base_motion_skill_node)<br/>[已实现]"]
    PATROL["路线巡逻执行器<br/>(patrol_executor_node / patrol_executor)<br/>[已实现]"]
