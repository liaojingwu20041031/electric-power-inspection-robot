  end
  block:L5
    columns 1
    H5["⑤ 硬件驱动与平台本地服务层"]
    BASEDRV["底盘驱动<br/>zlac8015d_canopen_controller<br/>STM32 回退: base_controller<br/>[已实现]"]
    SENSORDRV["传感器驱动<br/>rplidar_node / IMU_publisher / wtrtk980_nmea_node<br/>[RTK 可选]"]
    MAPMGR["MapManager / MapUploadWorker<br/>PlatformCloudClient<br/>[已实现；云连接可选]"]
  end
end

DRIVE["机器人硬件<br/>ZLAC8015D 控制器 + 轮毂电机<br/>[已实现]"]
SENSORS["机器人硬件<br/>RPLidar / IMU / RTK / ZED 2i<br/>麦克风 / 扬声器 / 触摸显示<br/>[RTK、ZED、语音可选]"]
LOCALMAP["本地数据存储<br/>my_map.yaml + my_map.pgm<br/>route_patrol_*.json / 归档<br/>[已实现]"]
LOCALDB["本地数据存储<br/>platform.db / 模型 / SVO / PLY / OBJ<br/>部署 / 命令 / 事件 / 上传任务<br/>[已实现或可选资产]"]
CLOUDDATA["平台数据存储<br/>地图资产 / Route Revision / Deployment<br/>[外部系统·协议已定义]"]

OP --> UI
OP --> VOICE
PHONE --> MB
WEB --> PLATFORM
