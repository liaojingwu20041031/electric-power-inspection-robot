<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="6" name="NavigateWaitRetry">
      <PipelineSequence name="NavigateWithRetry">
        <NormalizeGoal input_goal="{goal}" output_goal="{map_goal}" global_frame="map"/>
        <RateController hz="2.0">
          <RecoveryNode number_of_retries="2" name="ComputePathToPose">
            <ComputePathToPose goal="{map_goal}" path="{path}" planner_id="GridBased"/>
            <ClearEntireCostmap name="ClearGlobalCostmap" service_name="global_costmap/clear_entirely_global_costmap"/>
          </RecoveryNode>
        </RateController>
        <RecoveryNode number_of_retries="1" name="FollowPath">
          <FollowPath path="{path}" controller_id="FollowPath"/>
          <Sequence name="ClearLocalCostmapAndWait">
            <ClearEntireCostmap name="ClearLocalCostmap" service_name="local_costmap/clear_entirely_local_costmap"/>
            <Wait wait_duration="0.5"/>
          </Sequence>
        </RecoveryNode>
      </PipelineSequence>
      <ReactiveFallback name="SmallBackupRecovery">
        <GoalUpdated/>
        <Sequence name="WaitOnly">
          <Wait wait_duration="0.5"/>
        </Sequence>
      </ReactiveFallback>
    </RecoveryNode>
  </BehaviorTree>
</root>
